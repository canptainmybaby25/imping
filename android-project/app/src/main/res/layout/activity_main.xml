<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d0d0d"
    android:padding="8dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="#1a1a1a">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚛️ IMPGING Q-Engine"
            android:textColor="#00d4ff"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready"
            android:textColor="#aaaaaa"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Stats -->
    <TextView
        android:id="@+id/statsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:background="#141414"
        android:text="  🃏 CASINO: 0   🎮 GAMING: 0   ⚠️ ALERT: 0   ⚡ ENERGY: 1.00"
        android:textColor="#44ff88"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/scanBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:text="🔍 Scan"
            android:textSize="12sp" />

        <Button
            android:id="@+id/mimicBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:text="👁️ Mimic"
            android:textSize="12sp" />

        <Button
            android:id="@+id/monitorBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:text="📡 Monitor"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Process Table -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Detected Processes"
        android:textColor="#ffffff"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <!-- Table Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#2a2a2a"
        android:padding="4dp">

        <TextView android:layout_width="50dp"  android:layout_height="wrap_content" android:text="PID"      android:textColor="#aaaaaa" android:textSize="10sp" />
        <TextView android:layout_width="0dp"    android:layout_height="wrap_content" android:text="Process"  android:textColor="#aaaaaa" android:textSize="10sp" android:layout_weight="1" />
        <TextView android:layout_width="80dp"   android:layout_height="wrap_content" android:text="Class"    android:textColor="#aaaaaa" android:textSize="10sp" />
        <TextView android:layout_width="50dp"   android:layout_height="wrap_content" android:text="Conf"     android:textColor="#aaaaaa" android:textSize="10sp" />
        <TextView android:layout_width="50dp"   android:layout_height="wrap_content" android:text="Entropy"  android:textColor="#aaaaaa" android:textSize="10sp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/procScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#111111">

        <LinearLayout
            android:id="@+id/procContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Log -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entanglement Log"
        android:textColor="#ffffff"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingTop="6dp"
        android:paddingBottom="2dp" />

    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#0a0a0a">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="#00cc66"
            android:padding="4dp"
            android:text="" />
    </ScrollView>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚛️ Superposition · Interference · Wave Collapse · Entanglement"
        android:textColor="#444444"
        android:textSize="9sp"
        android:gravity="center"
        android:paddingTop="4dp" />

</LinearLayout>
